  </ItemGroup>

  <ItemGroup>
    <Reference Include="CommonConfigCompareClass">
      <HintPath>..\..\_TACT_DLL\_Debug\CommonConfigCompareClass.dll</HintPath>
    </Reference>
    <Reference Include="MKData">
      <HintPath>..\..\_TACT_DLL\_Debug\MKData.dll</HintPath>
    </Reference>
    <Reference Include="MKLog">
      <HintPath>..\..\_TACT_DLL\_Debug\MKLog.dll</HintPath>
    </Reference>
    <Reference Include="MKRemote">
      <HintPath>..\..\_TACT_DLL\_Debug\MKRemote.dll</HintPath>
    </Reference>
    <Reference Include="MKXML">
      <HintPath>..\..\_TACT_DLL\_Debug\MKXML.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
